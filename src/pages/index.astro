---
import Layout from '../layouts/Layout.astro';
import Logo from '../components/Logo.astro';
import PunchSection from '../components/sections/PunchSection.astro';
import { loadMainProgram } from '../pcob/loadProgram';
import '../styles/global.css';

// PCF_INCLUDE_INTERNAL is a build-time-only flag (see loadProgram.ts's loadMainProgram) —
// unset/anything else builds the public site; "true" builds the LAN-only variant that nginx
// serves to internal requesters (see docs/punch-card-content-system.md's Phase 7).
const includeInternal = process.env.PCF_INCLUDE_INTERNAL === 'true';
const program = loadMainProgram(includeInternal);

const navData = JSON.stringify({
    divisionMap: program.divisionMap,
    sectionsByDiv: program.sectionsByDiv,
    parasBySection: program.parasBySection,
});
---
<Layout>
    <Logo />
    {program.sections.map(section => (
        <PunchSection section={section} header={program.header} />
    ))}
    <div class="pcf-scroll-end-spacer"></div>
    <script type="application/json" id="pcf-nav-data" set:html={navData} />
    <script>
        import '../scripts/app.ts';
    </script>
</Layout>
