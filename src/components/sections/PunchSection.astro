---
// Generic renderer for a compiled section - replaces SectionTop/AboutMe/Work/Links.astro,
// which were four near-identical files each hardcoding their own section id, card lookups,
// and per-card scroll-distance math. Card order/count/id all come straight from the compiled
// section, so adding or reordering cards in a .pcob file needs no matching edit here.
//
// Impressum no longer needs to be an exception here (it did through Phase 6.3 - see
// docs/punch-card-content-system.md's decisions log): its legal-text overlay used to be
// genuinely bespoke Astro-side markup + a JS-measurement script, both replaced by a plain
// {{embed:path}} tag in impressum.pcob. Every section, including Impressum, renders through
// this one template now.
import type { CompiledHeader, CompiledSection, DivisionNavEntry } from '../../pcob/types';
import PunchCard from '../PunchCard.astro';

interface Props {
    section: CompiledSection;
    header: CompiledHeader;
    divisionNav: DivisionNavEntry[];
}

const { section, header, divisionNav } = Astro.props;
const isMulti = section.cards.length > 1;

// Fixed px, not vh - a scroll "tick" (mouse wheel notch) is a fixed pixel amount, not a
// percentage of viewport height, so a vh-based distance takes a different number of ticks
// on every monitor. ~100px/tick is the common Windows/Chrome default (3 lines); 2 ticks per
// card transition is the target - adjust PX_PER_CARD directly if your actual tick size differs.
const PX_PER_CARD = 200;
---
<section id={section.id} data-multi-card={String(isMulti)}>
{isMulti ? (
    <div class="section-scroll-container" style={`height: ${section.cards.length * PX_PER_CARD}px;`}>
        <div class="section-content-wrapper">
            <div class="pcf-stage-multi">
                {section.cards.map(card => (
                    <PunchCard
                        noStage={true}
                        header={header}
                        divisionNav={divisionNav}
                        lines={card.lines}
                        callLinks={card.callLinks}
                        embeds={card.embeds}
                    />
                ))}
            </div>
        </div>
    </div>
) : (
    <div class="section-scroll-container pcf-section-height">
        <div class="section-content-wrapper">
            <div class="pcf-stage">
                <PunchCard
                    noStage={true}
                    header={header}
                    divisionNav={divisionNav}
                    lines={section.cards[0].lines}
                    callLinks={section.cards[0].callLinks}
                    embeds={section.cards[0].embeds}
                />
            </div>
        </div>
    </div>
)}
</section>

<script>
// Side-effect import: multiCardSection.ts self-registers one scrollSync subscription that
// handles every multi-card section on the page, so there's nothing to call here per-section
// anymore. This script tag is byte-identical across all PunchSection instances, so Astro/the
// browser only ever runs it once, same dedup guarantee PunchCard.astro's own script relies on.
import '../../scripts/multiCardSection.ts';
</script>
