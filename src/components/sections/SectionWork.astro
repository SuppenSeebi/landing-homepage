---
import PunchCard from '../PunchCard.astro';
import { compileProgram } from '../../pcob/compile';
import workSource from '../../content/_punchcard/work.pcob?raw';

const compiled = compileProgram(workSource);
const workSection = compiled.sections.find(s => s.id === 'work')!;
const currentCard = workSection.cards.find(c => c.name === 'WORK-CURRENT')!;
const prevCard    = workSection.cards.find(c => c.name === 'WORK-PREV')!;

const CARD_COUNT = 2;
---
<section id="work">
    <div class="section-scroll-container" style={`height: ${CARD_COUNT * 88}vh;`}>
        <div class="section-content-wrapper">
            <div class="pcf-stage-multi">
                <PunchCard
                    noStage={true}
                    programName="SSCHW-DEV"
                    programmerName="SEBASTIAN SCHWINN"
                    currentSystem="RETROCODE GMBH"
                    identificationHref="#impressum"
                    lines={currentCard.lines}
                    callLinks={currentCard.callLinks}
                />
                <PunchCard
                    noStage={true}
                    programName="SSCHW-DEV"
                    programmerName="SEBASTIAN SCHWINN"
                    currentSystem="RETROCODE GMBH"
                    identificationHref="#impressum"
                    lines={prevCard.lines}
                    callLinks={prevCard.callLinks}
                />
            </div>
        </div>
    </div>
</section>

<script>
import { setupMultiCardSection } from '../../scripts/multiCardSection.ts';

setupMultiCardSection('work');

export function statemachineWorkRun() {}
(window as any).__workRun = statemachineWorkRun;
</script>
