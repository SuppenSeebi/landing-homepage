    ['000002', [['section',' LINKAGE SECTION'],['dot','.']]],
    ['000003', [['lvl',' 01'],['name',' WORKLOAD'],['dot','.']]],
    ['000004', []],
    ['000005', [['lvl','     05'],['name',' WORK-PREV'],['dot','.']]],
    ['000006', [['lvl','       10'],['name',' COMPANY'],['kw',' PIC X(30)'],['kw',' VALUE'],['val'," 'HILSCHER'"],['dot','.']]],
    ['000007', [['lvl','       10'],['name',' ROLE   '],['kw',' PIC X(30)'],['kw',' VALUE'],['val'," 'C DEVELOPER'"],['dot','.']]],
