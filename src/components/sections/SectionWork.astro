---
---
<section id="work">
    <div class="section-scroll-container">
        <div class="section-content-wrapper">
            <div class="work-container">
                <div class="cobol-block">

                    <div class="cobol-division">DATA DIVISION.</div>
                    <div class="cobol-section-hdr">LINKAGE SECTION.</div>

                    <div class="cobol-line l01 reveal-item">
                        <span class="lvl">01</span><span class="name">WORKLOAD.</span>
                    </div>

                    <!-- WORK-CURRENT -->
                    <div class="cobol-spacer"></div>
                    <div class="cobol-line l05 reveal-item">
                        <span class="lvl">05</span><span class="name">WORK-CURRENT.</span>
                    </div>
                    <div class="cobol-line l10 reveal-item">
                        <span class="lvl">10</span><span class="name">COMPANY</span><span class="pic">PIC X(30)</span><span class="kw">VALUE</span><span class="val">&apos;RETROCODE&apos;</span><span class="dot">.</span>
                    </div>
                    <div class="cobol-line l10 reveal-item">
                        <span class="lvl">10</span><span class="name">ROLE</span><span class="pic">PIC X(30)</span><span class="kw">VALUE</span><span class="val">&apos;COBOL DEVELOPER&apos;</span><span class="dot">.</span>
                    </div>
                    <div class="cobol-line l10 reveal-item">
                        <span class="lvl">10</span><span class="name">SECTOR</span><span class="pic">PIC X(25)</span><span class="kw">VALUE</span><span class="val">&apos;FINANCIAL SECTOR&apos;</span><span class="dot">.</span>
                    </div>
                    <div class="cobol-line l10 reveal-item">
                        <span class="lvl">10</span><span class="name">SINCE</span><span class="pic">PIC 9(4)</span><span class="kw">VALUE</span><span class="numval">2025</span><span class="dot">.</span>
                    </div>
                    <div class="cobol-line l10 reveal-item">
                        <span class="lvl">10</span><span class="name">PROFILE</span><span class="pic">PIC X(50)</span><span class="kw">VALUE</span><a class="val val-link" href="https://www.linkedin.com/in/sschwinn/" target="_blank" rel="noopener">&apos;linkedin.com/in/sschwinn/&apos;</a><span class="dot">.</span>
                    </div>

                    <!-- WORK-PREV -->
                    <div class="cobol-spacer"></div>
                    <div class="cobol-line l05 reveal-item">
                        <span class="lvl">05</span><span class="name">WORK-PREV.</span>
                    </div>
                    <div class="cobol-line l10 reveal-item">
                        <span class="lvl">10</span><span class="name">COMPANY</span><span class="pic">PIC X(30)</span><span class="kw">VALUE</span><span class="val">&apos;HILSCHER&apos;</span><span class="dot">.</span>
                    </div>
                    <div class="cobol-line l10 reveal-item">
                        <span class="lvl">10</span><span class="name">ROLE</span><span class="pic">PIC X(30)</span><span class="kw">VALUE</span><span class="val">&apos;C DEVELOPER&apos;</span><span class="dot">.</span>
                    </div>
                    <div class="cobol-line l10 reveal-item">
                        <span class="lvl">10</span><span class="name">TECH</span><span class="pic">PIC X(40)</span><span class="kw">VALUE</span><span class="val">&apos;OPC UA - INDUSTRIAL AUTOMATION&apos;</span><span class="dot">.</span>
                    </div>

                </div>
            </div>
        </div>
    </div>
</section>

<script>
let revealed = false;

export function statemachineWorkRun() {
    if (revealed) return;
    revealed = true;

    const items = document.querySelectorAll<HTMLElement>('#work .reveal-item');
    items.forEach((el, i) => setTimeout(() => el.classList.add('revealed'), i * 45));
}

(window as any).__workRun = statemachineWorkRun;
</script>
