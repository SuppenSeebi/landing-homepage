---
import PunchCard from '../PunchCard.astro';

type TT = 'div'|'section'|'para'|'lvl'|'name'|'kw'|'val'|'numval'|'dot'|'comment';
type Token = [TT, string];
type Line  = [string, Token[]];

const LINES: Line[] = [
    ['000001', [['div','PROCEDURE DIVISION'],['dot','.']]],
    ['000002', [['section','LINKS SECTION'],['dot','.']]],
    ['000003', []],
    ['000004', [['para','SERVICES-PRGRPH'],['dot','.']]],
    ['000005', [['kw','    CALL'],['val'," 'KB.SSCHW.DEV'"],['comment','  *> Personal wiki & notes']]],
    ['000006', [['kw','    CALL'],['val'," 'LLDAP'"],['comment','         *> Directory management (LAN)']]],
    ['000007', [['kw','    CALL'],['val'," 'BITWARDEN'"],['comment','     *> Password manager (LAN)']]],
    ['000008', [['dot','.']]],
    ['000009', []],
    ['000010', [['para','SOCIALS-PRGRPH'],['dot','.']]],
    ['000011', [['kw','    CALL'],['val'," 'LINKEDIN'"],['comment','      *> linkedin.com/in/sschwinn/']]],
    ['000012', [['kw','    CALL'],['val'," 'INSTAGRAM'"],['comment','     *> instagram.com/s.schwinni/']]],
    ['000013', [['dot','.']]],
    ['000014', []],
    ['000015', [['para','EXIT-PRGRPH'],['dot','.']]],
    ['000016', [['kw','    EXIT PARAGRAPH'],['dot','.']]],
    ['000017', []],
    ['000018', []],
];

const CALL_LINKS: Record<string, string> = {
    " 'KB.SSCHW.DEV'": 'https://kb.sschw.dev',
    " 'LINKEDIN'":      'https://www.linkedin.com/in/sschwinn/',
    " 'INSTAGRAM'":     'https://www.instagram.com/s.schwinni/',
};
---
<section id="links">
    <div class="section-scroll-container pcf-section-height">
        <div class="section-content-wrapper">
            <PunchCard
                programName="SSCHW-DEV"
                programmerName="SEBASTIAN SCHWINN"
                currentSystem="RETROCODE GMBH"
                identificationHref="#impressum"
                lines={LINES}
                callLinks={CALL_LINKS}
            />
        </div>
    </div>
</section>

<script>
export function statemachineLinksRun() {}
(window as any).__linksRun = statemachineLinksRun;
</script>
