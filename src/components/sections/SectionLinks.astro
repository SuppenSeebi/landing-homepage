<script>
async function checkLocalNetwork() {
    try {
        const controller = new AbortController();
        const timeout = setTimeout(() => controller.abort(), 1500);
        const res = await fetch("/api/network-check", { signal: controller.signal });
        clearTimeout(timeout);
        if (res.ok) {
            document.querySelectorAll<HTMLElement>(".service-card.lan-only").forEach(el => {
                el.classList.add("lan-visible");
            });
        }
    } catch {
        /* public visitor or request timed out — lan cards stay hidden */
    }
}

checkLocalNetwork();

export function statemachineLinksRun() {}
(window as any).__linksRun = statemachineLinksRun;
</script>
