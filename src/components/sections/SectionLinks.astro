<script>
async function checkLocalNetwork() {
    try {
        const controller = new AbortController();
        const timeout = setTimeout(() => controller.abort(), 1500);
        const res = await fetch("/api/network-check", { signal: controller.signal });
        clearTimeout(timeout);
        if (res.ok) {
            document.querySelectorAll<HTMLElement>(".lan-group.lan-only").forEach(el => {
                el.classList.add("lan-visible");
            });
        }
    } catch {
        /* public visitor or request timed out — lan block stays hidden */
    }
}

checkLocalNetwork();

export function statemachineLinksRun() {
    const items = document.querySelectorAll<HTMLElement>('#links .reveal-item');
    items.forEach((el, i) => setTimeout(() => el.classList.add('revealed'), i * 60));
}
(window as any).__linksRun = statemachineLinksRun;
</script>
