---
import PunchCard from '../PunchCard.astro';

type TT = 'div'|'section'|'para'|'lvl'|'name'|'kw'|'val'|'numval'|'dot'|'comment';
type Token = [TT, string];
type Line  = [string, Token[]];

const LINES: Line[] = [
    ['000001', [['div','PROTOTYPE DIVISION'],['dot','.']]],
    ['000002', [['section','CARD-TEXTURE SECTION'],['dot','.']]],
    ['000003', []],
    ['000004', [['lvl','01'],['name',' DEMO-RECORD'],['dot','.']]],
    ['000005', []],
    ['000006', [['lvl','    05'],['name',' APPROACH   '],['kw',' PIC X(30)'],['kw',' VALUE'],['val'," 'CARD-AS-BACKGROUND-TEXTURE'"],['dot','.']]],
    ['000007', [['lvl','    05'],['name',' TRANSITIONS'],['kw',' PIC X(30)'],['kw',' VALUE'],['val'," 'HORIZONTAL PAN BETWEEN CARDS'"],['dot','.']]],
    ['000008', [['lvl','    05'],['name',' SCROLL     '],['kw',' PIC X(30)'],['kw',' VALUE'],['val'," 'SECTION FLOWS ON CARD PAPER'"],['dot','.']]],
    ['000009', []],
    ['000010', [['lvl','    05'],['name',' CARD-COLS  '],['kw',' PIC 9(2) '],['kw',' VALUE'],['numval','  80'],['dot','.']]],
    ['000011', [['lvl','    05'],['name',' CARD-ROWS  '],['kw',' PIC 9(2) '],['kw',' VALUE'],['numval','  12'],['dot','.']]],
    ['000012', []],
    ['000013', [['lvl','    05'],['name',' FEEL       '],['kw',' PIC X(50)'],['kw',' VALUE'],['val'," 'SAME CONTENT LANGUAGE, NEW MATERIAL'"],['dot','.']]],
    ['000014', []],
    ['000015', [['comment','*> PROTOTYPE B: CARD AS BACKGROUND TEXTURE']]],
    ['000016', [['comment','*> Demonstrates use of punch card as page background']]],
    ['000017', []],
    ['000018', []],
];
---
<section id="demo-texture">
    <div class="section-scroll-container pcf-section-height">
        <div class="section-content-wrapper">
            <PunchCard
                programName="SSCHW-DEV"
                programmerName="SEBASTIAN SCHWINN"
                currentSystem="RETROCODE GMBH"
                identificationHref="#impressum"
                lines={LINES}
            />
        </div>
    </div>
</section>
