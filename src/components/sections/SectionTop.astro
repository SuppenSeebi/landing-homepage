---
import PunchCard from '../PunchCard.astro';
import { compileProgram } from '../../pcob/compile';
import topSource from '../../content/_punchcard/top.pcob?raw';

const compiled = compileProgram(topSource);
const topSection = compiled.sections.find(s => s.id === 'top')!;
const CARD_NAMES = ['IDENTITY', 'BACKGROUND', 'CAREER-CURR', 'CAREER-PREV', 'SKILLS', 'INTERESTS', 'COMMUNITY'];
const CARDS = CARD_NAMES.map(name => topSection.cards.find(c => c.name === name)!);
const CARD_COUNT = CARDS.length;
---
<section id="top">
    <div class="section-scroll-container" style={`height: ${CARD_COUNT * 88}vh;`}>
        <div class="section-content-wrapper">
            <div class="pcf-stage-multi">
                {CARDS.map(card => (
                    <PunchCard
                        noStage={true}
                        programName="SSCHW-DEV"
                        programmerName="SEBASTIAN SCHWINN"
                        currentSystem="RETROCODE GMBH"
                        identificationHref="#impressum"
                        lines={card.lines}
                        callLinks={card.callLinks}
                    />
                ))}
            </div>
        </div>
    </div>
</section>

<script>
import { setupMultiCardSection } from '../../scripts/multiCardSection.ts';

setupMultiCardSection('top');

export function statemachineTopRun() {}
(window as any).__topRun = statemachineTopRun;
</script>
