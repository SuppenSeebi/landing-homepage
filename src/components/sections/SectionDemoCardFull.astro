---
const compiled = new Date().toISOString().slice(0, 10);
---
<section id="demo-full">
    <div class="section-scroll-container pcf-section-height">
        <div class="section-content-wrapper">
            <div class="pcf-stage">
                <span class="pcf-proto-tag">PROTOTYPE A · CARD AS PAGE OBJECT</span>
                <div class="pcf-card">

                    <!-- ── Card header strip ── -->
                    <div class="pcf-header">
                        <span class="pcf-hdr-brand">IBM 026 KEYPUNCH · COBOL SOURCE DECK</span>
                        <div class="pcf-hdr-meta">
                            <span class="pcf-hdr-field">PROGRAM-ID <span class="pcf-hdr-val">SSCHW-DEV</span></span>
                            <span class="pcf-hdr-dot">·</span>
                            <span class="pcf-hdr-field">AUTHOR <span class="pcf-hdr-val">SEBASTIAN SCHWINN</span></span>
                            <span class="pcf-hdr-dot">·</span>
                            <span class="pcf-hdr-field">DATE-COMPILED <span class="pcf-hdr-val">{compiled}</span></span>
                        </div>
                    </div>

                    <!-- ── Main: row labels + punch body ── -->
                    <div class="pcf-main">

                        <!-- Row number column -->
                        <div class="pcf-rows">
                            <div class="pcf-rows-corner"></div>
                            <div class="pcf-row-num">12</div>
                            <div class="pcf-row-num">11</div>
                            <div class="pcf-row-num">0</div>
                            <div class="pcf-row-num">1</div>
                            <div class="pcf-row-num">2</div>
                            <div class="pcf-row-num">3</div>
                            <div class="pcf-row-num">4</div>
                            <div class="pcf-row-num">5</div>
                            <div class="pcf-row-num">6</div>
                            <div class="pcf-row-num">7</div>
                            <div class="pcf-row-num">8</div>
                            <div class="pcf-row-num">9</div>
                        </div>

                        <!-- Ruler + punch area -->
                        <div class="pcf-body">
                            <div class="pcf-ruler-row">
                                <div class="pcf-seq pcf-seq-hdr"></div>
                                <div class="pcf-ruler-track" id="pcf-ruler-track"></div>
                            </div>
                            <div class="pcf-punch-area" id="pcf-punch-area"></div>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
type TT = 'div'|'section'|'para'|'lvl'|'name'|'kw'|'val'|'numval'|'dot'|'comment';
type Token = [TT, string];
type Line  = [string, Token[]];

const LINES: Line[] = [
    ['000001', [['div','DATA DIVISION'],['dot','.']]],
    ['000002', [['section','WORKING-STORAGE SECTION'],['dot','.']]],
    ['000003', [['lvl','01'],['name',' SSCHW-RECORD'],['dot','.']]],
    ['000004', [['lvl','    05'],['name',' NAME    '],['kw',' PIC X(50)'],['kw','  VALUE'],['val'," 'SEBASTIAN SCHWINN'"],['dot','.']]],
    ['000005', [['lvl','    05'],['name',' ROLE    '],['kw',' PIC X(40)'],['kw','  VALUE'],['val'," 'COBOL DEVELOPER'"],['dot','.']]],
    ['000006', [['lvl','    05'],['name',' YEAR    '],['kw',' PIC 9(4) '],['kw','  VALUE'],['numval',' 2025'],['dot','.']]],
    ['000007', [['lvl','    88'],['name',' ACTIVE  '],['kw','           VALUE'],['numval',' 2025'],['dot','.']]],
    ['000008', []],
    ['000009', [['div','PROCEDURE DIVISION'],['dot','.']]],
    ['000010', [['para','MAIN-PRGRPH'],['dot','.']]],
    ['000011', [['kw','    DISPLAY'],['name',' NAME'],['comment','                        *> prints to SYSOUT']]],
    ['000012', [['kw','    MOVE'],['val'," 'ENGINEER'"],['kw',' TO'],['name',' ROLE'],['kw','    PERFORM'],['name',' INIT-PRGRPH']]],
];

const COLS = 80;

const CLS: Record<TT, string> = {
    div:     'pcc-div',
    section: 'pcc-section',
    para:    'pcc-para',
    lvl:     'pcc-lvl',
    name:    'pcc-name',
    kw:      'pcc-kw',
    val:     'pcc-val',
    numval:  'pcc-numval',
    dot:     'pcc-dot',
    comment: 'pcc-comment',
};

// Ruler: 8 ticks of 10ch each — inherits card base font so 10ch aligns with 10 content spans
const rulerEl = document.getElementById('pcf-ruler-track')!;
for (let c = 10; c <= COLS; c += 10) {
    const tick = document.createElement('span');
    tick.className = 'pcf-ruler-tick';
    tick.textContent = String(c);
    rulerEl.appendChild(tick);
}

// Punch rows
const area = document.getElementById('pcf-punch-area')!;
for (const [seq, tokens] of LINES) {
    const chars: [string, string][] = [];
    for (const [type, text] of tokens) {
        for (const ch of text) chars.push([ch, CLS[type]]);
    }
    while (chars.length < COLS) chars.push([' ', 'pcc-kw']);

    const row = document.createElement('div');
    row.className = 'pcf-line-row';

    const seqEl = document.createElement('div');
    seqEl.className = 'pcf-seq';
    seqEl.textContent = seq;
    row.appendChild(seqEl);

    const charsEl = document.createElement('div');
    charsEl.className = 'pcf-chars';
    for (let i = 0; i < COLS; i++) {
        const [ch, cls] = chars[i];
        const span = document.createElement('span');
        if (ch === ' ') {
            span.className = 'pcc-empty';
        } else {
            span.className = cls;
            span.textContent = ch;
        }
        charsEl.appendChild(span);
    }
    row.appendChild(charsEl);
    area.appendChild(row);
}
</script>

<style is:global>
/* ── PROTOTYPE A: PUNCH CARD AS PAGE OBJECT ─────────────────────────────── */

/* Taller section so the card has room to breathe */
.pcf-section-height {
    height: 92vh;
}

.pcf-stage {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    padding: 3vh 4%;
    gap: 8px;
}

.pcf-proto-tag {
    font-family: "Share Tech Mono", monospace;
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    align-self: flex-start;
}

/* Card: column flex so header stacks above main content */
.pcf-card {
    display: flex;
    flex-direction: column;
    width: 100%;
    flex: 1;
    min-height: 0;
    background: #F5EDD4;
    border: 1.5px solid #C2A840;
    clip-path: polygon(22px 0%, 100% 0%, 100% 100%, 0% 100%, 0% 22px);
    box-shadow: 0 8px 32px rgba(0,0,0,0.28), 0 2px 8px rgba(0,0,0,0.14);
    overflow: hidden;
    font-family: "Share Tech Mono", monospace;
    /* Base font — ruler ticks (10ch) and content spans (1ch) both inherit this
       so column alignment is guaranteed */
    font-size: clamp(1.1rem, 1.8vw, 1.8rem);
}

/* ── Card header strip ───────────────────────────────────────────────────── */
.pcf-header {
    display: flex;
    flex-direction: row;
    align-items: center;
    padding: 0 16px 0 32px; /* 32px left clears the corner clip */
    height: 38px;
    background: #EDE0A8;
    border-bottom: 2px solid #C2A840;
    flex-shrink: 0;
    gap: 16px;
    overflow: hidden;
}

.pcf-hdr-brand {
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    color: #7A6020;
    white-space: nowrap;
    flex-shrink: 0;
}

.pcf-hdr-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-left: auto;
    overflow: hidden;
}

.pcf-hdr-field {
    font-size: 0.6rem;
    color: #9B8050;
    white-space: nowrap;
}

.pcf-hdr-val {
    color: #1A0E00;
}

.pcf-hdr-dot {
    color: #C8AE58;
    font-size: 0.6rem;
    flex-shrink: 0;
}

/* ── Main: row labels + punch body ──────────────────────────────────────── */
.pcf-main {
    display: flex;
    flex-direction: row;
    flex: 1;
    min-height: 0;
    overflow: hidden;
}

/* ── Row number labels (left edge) ─────────────────────────────────────── */
.pcf-rows {
    display: flex;
    flex-direction: column;
    background: #EDE0A8;
    border-right: 1.5px solid #C2A840;
    flex-shrink: 0;
}

/* Aligns with the ruler row height */
.pcf-rows-corner {
    height: 28px;
    border-bottom: 1.5px solid #C2A840;
    flex-shrink: 0;
}

.pcf-row-num {
    flex: 1;
    min-height: 0;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding: 0 6px;
    font-size: 0.62rem;
    color: #7A6020;
    border-bottom: 1px solid #D4C478;
}

/* ── Body column: ruler + punch rows ───────────────────────────────────── */
.pcf-body {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-width: 0;
    overflow: hidden;
}

/* Ruler row */
.pcf-ruler-row {
    display: flex;
    flex-direction: row;
    height: 28px;
    background: #EDE0A8;
    border-bottom: 1.5px solid #C2A840;
    flex-shrink: 0;
    align-items: center;
    overflow: hidden;
}

/* Spacer above seq column — fixed px width matches pcf-seq */
.pcf-seq-hdr {
    width: 72px;
    border-right: 1.5px solid #C2A840;
    height: 100%;
    flex-shrink: 0;
}

/* Ruler track: flex of 8 ticks × 10ch each.
   No explicit font-size — inherits pcf-card base so 10ch = 10 × content-span-ch */
.pcf-ruler-track {
    display: flex;
    align-items: center;
    flex: 1;
    overflow: hidden;
}

.pcf-ruler-tick {
    display: inline-block;
    width: 10ch;
    text-align: right;
    color: #9B8050;
    flex-shrink: 0;
    /* intentionally no font-size override — must match content span ch */
}

/* Punch area: 12 rows */
.pcf-punch-area {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-height: 0;
    overflow: hidden;
}

/* Each punch row: seq | 80 chars */
.pcf-line-row {
    display: flex;
    flex-direction: row;
    align-items: stretch;
    flex: 1;
    min-height: 0;
    border-bottom: 1px solid #D4C478;
}

/* Sequence number column — fixed px width so it matches pcf-seq-hdr */
.pcf-seq {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding: 0 6px;
    width: 72px;
    font-size: 0.62rem;
    color: var(--text-muted);
    background: #EDE0A8;
    border-right: 1.5px solid #C2A840;
    flex-shrink: 0;
    white-space: nowrap;
}

/* 80-column character area */
.pcf-chars {
    display: flex;
    align-items: center;
    overflow: hidden;
    flex: 1;
}

/* Every span occupies exactly 1ch — ruler ticks are 10ch, so alignment is guaranteed */
.pcf-chars span {
    display: inline-block;
    width: 1ch;
    text-align: center;
    line-height: 1;
    position: relative;
    flex-shrink: 0;
}

/* Non-punched position: 2px centered dot */
.pcc-empty::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 2.5px;
    height: 2.5px;
    background: #C8AE58;
    border-radius: 50%;
}

/* ── Token type colors ───────────────────────────────────────────────────── */
.pcc-div     { color: #1A0E00; }
.pcc-section { color: #2C1A00; }
.pcc-para    { color: var(--blue-darker-1); }
.pcc-lvl     { color: var(--text-muted); }
.pcc-name    { color: var(--blue-darker-2); }
.pcc-kw      { color: #8B7040; }
.pcc-val     { color: var(--blue-primary); }
.pcc-numval  { color: var(--blue-primary); }
.pcc-dot     { color: #8B7040; }
.pcc-comment { color: #9B8050; font-style: italic; }
</style>
