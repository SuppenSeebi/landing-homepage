---
const compiled = new Date().toISOString().slice(0, 10);
---
<section id="demo-full">
    <div class="section-scroll-container pcf-section-height">
        <div class="section-content-wrapper">
            <div class="pcf-stage">
                <div class="pcf-card">

                    <!-- ── Title bar ── -->
                    <div class="pcf-title-bar">
                        <span class="pcf-title-side">Program Information</span>
                        <span class="pcf-title-name">Program Navigation</span>
                        <span class="pcf-title-side pcf-title-right">COBOL CODING FORM&nbsp;&nbsp;C61897 · 80-COL&nbsp;&nbsp;18&nbsp;ROW</span>
                    </div>

                    <!-- ── 3-row form header ── -->
                    <div class="pcf-form-header">

                        <!-- Row 1: PROGRAMMER · DIVISION nav · PAGE -->
                        <div class="pcf-fh-row">
                            <div class="pcf-fh-cell pcf-fh-w1">
                                <span class="pcf-fh-lbl">PROGRAMMER</span>
                                <span class="pcf-fh-val">SEBASTIAN SCHWINN</span>
                            </div>
                            <div class="pcf-fh-cell pcf-fh-w2 pcf-fh-nav-cell">
                                <span class="pcf-fh-lbl">DIVISION</span>
                                <div class="pcf-fh-nav">
                                    <a class="pcf-div-item" data-div="data"  href="#top"      >DATA DIVISION</a>
                                    <span class="pcf-nav-dot">·</span>
                                    <a class="pcf-div-item" data-div="proc"  href="#links"    >PROCEDURE DIVISION</a>
                                    <span class="pcf-nav-dot">·</span>
                                    <a class="pcf-div-item" data-div="proto" href="#demo-full">PROTOTYPE DIVISION</a>
                                </div>
                            </div>
                            <div class="pcf-fh-cell pcf-fh-w3">
                                <span class="pcf-fh-lbl">PAGE</span>
                                <span class="pcf-fh-val">1&nbsp;OF&nbsp;1</span>
                            </div>
                        </div>

                        <!-- Row 2: PROGRAM · SECTION nav · IDENTIFICATION → #impressum -->
                        <div class="pcf-fh-row">
                            <div class="pcf-fh-cell pcf-fh-w1">
                                <span class="pcf-fh-lbl">PROGRAM</span>
                                <span class="pcf-fh-val">SSCHW-DEV</span>
                            </div>
                            <div class="pcf-fh-cell pcf-fh-w2 pcf-fh-nav-cell">
                                <span class="pcf-fh-lbl">SECTION</span>
                                <div class="pcf-fh-nav" id="pcf-nav-sec"></div>
                            </div>
                            <a class="pcf-fh-cell pcf-fh-w3 pcf-fh-id" href="#impressum">
                                <span class="pcf-fh-lbl">IDENTIFICATION</span>
                                <div class="pcf-id-track">
                                    <span class="pcf-id-n">73</span>
                                    <span class="pcf-id-box"></span><span class="pcf-id-box"></span>
                                    <span class="pcf-id-box"></span><span class="pcf-id-box"></span>
                                    <span class="pcf-id-box"></span><span class="pcf-id-box"></span>
                                    <span class="pcf-id-box"></span><span class="pcf-id-box"></span>
                                    <span class="pcf-id-n">80</span>
                                </div>
                            </a>
                        </div>

                        <!-- Row 3: SYSTEM · DATE · PUNCH -->
                        <div class="pcf-fh-row">
                            <div class="pcf-fh-cell pcf-fh-w1">
                                <span class="pcf-fh-lbl">SYSTEM</span>
                                <span class="pcf-fh-val">RETROCODE CORPORATION</span>
                            </div>
                            <div class="pcf-fh-cell pcf-fh-w2">
                                <span class="pcf-fh-lbl">DATE</span>
                                <span class="pcf-fh-val">{compiled}</span>
                            </div>
                            <div class="pcf-fh-cell pcf-fh-w3">
                                <span class="pcf-fh-lbl">PUNCH</span>
                            </div>
                        </div>

                    </div>

                    <!-- ── Coding area ── -->
                    <div class="pcf-coding-area">

                        <div class="pcf-zone-row">
                            <div class="pcf-zone-linenum">LINE</div>
                            <div class="pcf-zone-seq">SEQUENCE</div>
                            <div class="pcf-zone-stmt">COBOL STATEMENT</div>
                        </div>

                        <div class="pcf-ruler-row">
                            <div class="pcf-ruler-linenum"></div>
                            <div class="pcf-ruler-seq" id="pcf-rseq-top"></div>
                            <div class="pcf-ruler-chars" id="pcf-rchars-top"></div>
                        </div>

                        <div class="pcf-punch-area" id="pcf-punch-area"></div>

                        <div class="pcf-ruler-row pcf-ruler-btm">
                            <div class="pcf-ruler-linenum"></div>
                            <div class="pcf-ruler-seq" id="pcf-rseq-btm"></div>
                            <div class="pcf-ruler-chars" id="pcf-rchars-btm"></div>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
// ── Navigation ─────────────────────────────────────────────────────────────
const DIVISION_MAP: Record<string,string[]> = {
    data:  ['top','aboutme','work'],
    proc:  ['links','impressum'],
    proto: ['demo-full','demo-texture'],
};
const SECTIONS_BY_DIV: Record<string,{label:string;href:string}[]> = {
    data:  [
        {label:'WORKING-STORAGE.', href:'#top'},
        {label:'LOCAL-STORAGE.',   href:'#aboutme'},
        {label:'LINKAGE SECTION.', href:'#work'},
    ],
    proc:  [
        {label:'LINKS SECTION.',     href:'#links'},
        {label:'IMPRESSUM-SECTION.', href:'#impressum'},
    ],
    proto: [
        {label:'PROTO-A FULL-CARD.', href:'#demo-full'},
        {label:'PROTO-B TEXTURE.',   href:'#demo-texture'},
    ],
};

const secNav = document.getElementById('pcf-nav-sec')!;
for (const [divId, secs] of Object.entries(SECTIONS_BY_DIV)) {
    const grp = document.createElement('div');
    grp.className = 'pcf-sec-group';
    grp.dataset.div = divId;
    secs.forEach((sec, i) => {
        if (i > 0) { const d=document.createElement('span'); d.className='pcf-nav-dot'; d.textContent='·'; grp.appendChild(d); }
        const a = document.createElement('a');
        a.className = 'pcf-sec-item';
        a.href = sec.href;
        a.textContent = sec.label;
        grp.appendChild(a);
    });
    secNav.appendChild(grp);
}

function getActiveId(): string {
    const mid = window.scrollY + window.innerHeight / 2;
    let active = 'top';
    document.querySelectorAll<HTMLElement>('section').forEach(s => {
        if (mid >= s.offsetTop && mid < s.offsetTop + s.offsetHeight) active = s.id;
    });
    return active;
}
function getActiveDivId(id: string): string {
    for (const [div, ids] of Object.entries(DIVISION_MAP)) { if (ids.includes(id)) return div; }
    return 'data';
}
function updatePcfNav(activeId: string) {
    const divId = getActiveDivId(activeId);
    document.querySelectorAll<HTMLElement>('.pcf-div-item').forEach(el =>
        el.classList.toggle('pcf-nav-active', el.dataset.div === divId));
    document.querySelectorAll<HTMLElement>('.pcf-sec-group').forEach(el =>
        ((el as HTMLElement).style.display = el.dataset.div === divId ? 'flex' : 'none'));
    document.querySelectorAll<HTMLElement>('.pcf-sec-item').forEach(el =>
        el.classList.toggle('pcf-nav-active', el.getAttribute('href') === `#${activeId}`));
}
window.addEventListener('scroll', () => updatePcfNav(getActiveId()), {passive:true});
updatePcfNav(getActiveId());

// ── Seq rulers — space-evenly matches the per-digit content spans ───────────
function buildSeqRuler(id: string) {
    const el = document.getElementById(id)!;
    for (let i = 1; i <= 6; i++) {
        const s = document.createElement('span');
        s.className = 'pcf-rseq-tick';
        s.textContent = String(i);
        el.appendChild(s);
    }
}
buildSeqRuler('pcf-rseq-top');
buildSeqRuler('pcf-rseq-btm');

// ── Chars ruler — pixel-accurate: measure a real content span after render ──
function buildCharsRulers() {
    const sampleSpan = document.querySelector<HTMLElement>('#pcf-punch-area .pcf-chars span');
    if (!sampleSpan) return;
    const chPx = sampleSpan.getBoundingClientRect().width;
    if (chPx <= 0) return;
    const tickPx = chPx * 4;  // one tick = 4 content columns

    for (const id of ['pcf-rchars-top', 'pcf-rchars-btm']) {
        const el = document.getElementById(id)!;
        el.innerHTML = '';
        // 20 ticks × 4 cols = 80 cols total
        for (let c = 4; c <= 80; c += 4) {
            const s = document.createElement('span');
            s.className = 'pcf-rchars-tick';
            s.textContent = String(c);
            s.style.width = `${tickPx}px`;
            el.appendChild(s);
        }
    }
}

// ── Content lines ──────────────────────────────────────────────────────────
type TT = 'div'|'section'|'para'|'lvl'|'name'|'kw'|'val'|'numval'|'dot'|'comment';
type Token = [TT, string];
type Line  = [string, Token[]];

const LINES: Line[] = [
    ['000001',[['div','DATA DIVISION'],['dot','.']]],
    ['000002',[['section','WORKING-STORAGE SECTION'],['dot','.']]],
    ['000003',[['lvl','01'],['name',' SSCHW-RECORD'],['dot','.']]],
    ['000004',[['lvl','    05'],['name',' NAME    '],['kw',' PIC X(50)'],['kw','  VALUE'],['val'," 'SEBASTIAN SCHWINN'"],['dot','.']]],
    ['000005',[['lvl','    05'],['name',' ROLE    '],['kw',' PIC X(40)'],['kw','  VALUE'],['val'," 'COBOL DEVELOPER'"],['dot','.']]],
    ['000006',[['lvl','    05'],['name',' YEAR    '],['kw',' PIC 9(4) '],['kw','  VALUE'],['numval',' 2025'],['dot','.']]],
    ['000007',[['lvl','    88'],['name',' ACTIVE  '],['kw','           VALUE'],['numval',' 2025'],['dot','.']]],
    ['000008',[['lvl','01'],['name',' WORK-VARS'],['dot','.']]],
    ['000009',[['lvl','    05'],['name',' WS-STATUS'],['kw',' PIC X(10)'],['kw','  VALUE'],['val'," 'AVAILABLE'"],['dot','.']]],
    ['000010',[['lvl','    05'],['name',' WS-CTR   '],['kw',' PIC 9(3) '],['kw','  VALUE'],['numval','  000'],['dot','.']]],
    ['000011',[]],
    ['000012',[['div','PROCEDURE DIVISION'],['dot','.']]],
    ['000013',[['para','MAIN-PRGRPH'],['dot','.']]],
    ['000014',[['kw','    DISPLAY'],['name',' NAME']]],
    ['000015',[['kw','    PERFORM'],['name',' INIT-PRGRPH'],['kw',' THRU'],['name',' INIT-END']]],
    ['000016',[['kw','    MOVE'],['val'," 'ENGINEER'"],['kw',' TO'],['name',' ROLE']]],
    ['000017',[['kw','    STOP RUN'],['dot','.']]],
    ['000018',[['para','INIT-PRGRPH'],['dot','.']]],
];

const COLS = 80;
const CLS: Record<TT,string> = {
    div:'pcc-div', section:'pcc-section', para:'pcc-para', lvl:'pcc-lvl',
    name:'pcc-name', kw:'pcc-kw', val:'pcc-val', numval:'pcc-numval',
    dot:'pcc-dot', comment:'pcc-comment',
};

const area = document.getElementById('pcf-punch-area')!;
LINES.forEach(([seq, tokens], idx) => {
    const chars: [string,string][] = [];
    for (const [type, text] of tokens) for (const ch of text) chars.push([ch, CLS[type]]);
    while (chars.length < COLS) chars.push([' ','pcc-kw']);

    const row = document.createElement('div');
    row.className = 'pcf-line-row';

    // Line number
    const lineNum = document.createElement('div');
    lineNum.className = 'pcf-line-num';
    lineNum.textContent = String(idx + 1).padStart(2, '0');
    row.appendChild(lineNum);

    // Sequence number: one span per digit so space-evenly matches the ruler
    const seqEl = document.createElement('div');
    seqEl.className = 'pcf-seq';
    for (const ch of seq) {
        const s = document.createElement('span');
        s.className = 'pcf-seq-digit';
        s.textContent = ch;
        seqEl.appendChild(s);
    }
    row.appendChild(seqEl);

    // 80-col content
    const charsEl = document.createElement('div');
    charsEl.className = 'pcf-chars';
    for (let i = 0; i < COLS; i++) {
        const [ch, cls] = chars[i];
        const span = document.createElement('span');
        if (ch === ' ') { span.className = 'pcc-empty'; }
        else { span.className = cls; span.textContent = ch; }
        charsEl.appendChild(span);
    }
    row.appendChild(charsEl);
    area.appendChild(row);
});

// Measure after first paint so ruler pixel widths are accurate
requestAnimationFrame(buildCharsRulers);
window.addEventListener('resize', buildCharsRulers, {passive: true});
</script>

<style is:global>
/* ── SECTION ────────────────────────────────────────────────────────────── */
.pcf-section-height { height: 88vh; }

.pcf-stage {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    padding: 7vh 7%;
}

/* ── CARD ───────────────────────────────────────────────────────────────── */
.pcf-card {
    display: flex;
    flex-direction: column;
    width: 85%;
    flex: 1;
    min-height: 0;
    background-color: #F5EDD4;
    background-image:
        radial-gradient(ellipse 80% 60% at 6% 94%,  rgba(155,95,15,0.16) 0%, transparent 55%),
        radial-gradient(ellipse 60% 50% at 94% 6%,  rgba(155,95,15,0.11) 0%, transparent 50%),
        radial-gradient(ellipse 40% 35% at 60% 50%, rgba(195,155,55,0.06) 0%, transparent 45%),
        linear-gradient(170deg, rgba(255,250,225,0.22) 0%, transparent 30%);
    border: 1.5px solid #C2A840;
    clip-path: polygon(22px 0%, 100% 0%, 100% 100%, 0% 100%, 0% 22px);
    box-shadow: 0 8px 32px rgba(0,0,0,0.28), 0 2px 8px rgba(0,0,0,0.14),
                inset 0 0 80px rgba(139,90,20,0.07);
    overflow: hidden;
    font-family: "Share Tech Mono", monospace;
    font-size: clamp(0.9rem, 1.5vw, 1.4rem);
}

/* ── TITLE BAR ──────────────────────────────────────────────────────────── */
.pcf-title-bar {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: 0 12px 0 32px;
    height: 28px;
    background: #EDE0A8;
    border-bottom: 1.5px solid #C2A840;
    flex-shrink: 0;
}
/* Left and right share the same font — both are descriptive labels */
.pcf-title-side {
    font-size: 0.60rem;
    font-weight: 400;
    color: #7A6020;
    letter-spacing: 0.04em;
}
.pcf-title-right { text-align: right; }
/* Center is the prominent title */
.pcf-title-name {
    font-size: 0.84rem;
    font-weight: 700;
    color: #2C1A00;
    letter-spacing: 0.12em;
    text-align: center;
}

/* ── FORM HEADER ────────────────────────────────────────────────────────── */
.pcf-form-header {
    display: flex;
    flex-direction: column;
    border-bottom: 2px solid #C2A840;
    flex-shrink: 0;
    background-image: radial-gradient(ellipse at 4% 50%, rgba(155,95,15,0.05) 0%, transparent 40%);
}
.pcf-fh-row {
    display: flex;
    flex-direction: row;
    border-bottom: 1px solid #D4C478;
}
.pcf-fh-row:last-child { border-bottom: none; }

.pcf-fh-cell {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 3px 8px;
    border-right: 1px solid #D4C478;
    min-height: 26px;
    gap: 1px;
    min-width: 0;
    overflow: hidden;
}
.pcf-fh-cell:last-child { border-right: none; }

.pcf-fh-w1 { flex: 2.5; }
.pcf-fh-w2 { flex: 3.5; }
.pcf-fh-w3 { flex: 1.5; }

/* Nav cells: subtle amber left-border signals interactivity */
.pcf-fh-nav-cell {
    border-left: 3px solid rgba(194,168,64,0.45);
    padding-left: 6px;
}

.pcf-fh-lbl {
    font-size: 0.4rem;
    color: #9B8050;
    letter-spacing: 0.07em;
    white-space: nowrap;
    line-height: 1;
}
.pcf-fh-val {
    font-size: 0.68rem;
    color: #1A0E00;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    line-height: 1.15;
}

/* Nav rows (DIVISION / SECTION) */
.pcf-fh-nav {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 5px;
    flex-wrap: nowrap;
    overflow: hidden;
}
.pcf-sec-group {
    display: none;
    flex-direction: row;
    align-items: center;
    gap: 5px;
}
.pcf-nav-dot {
    font-size: 0.5rem;
    color: #C8AE58;
    flex-shrink: 0;
}

/* Nav items: column layout, larger than labels, dashed underline on hover */
.pcf-div-item, .pcf-sec-item {
    font-size: 0.68rem;
    color: #9B8050;
    text-decoration: none;
    white-space: nowrap;
    letter-spacing: 0.02em;
    border-bottom: 1px dashed transparent;
    padding-bottom: 1px;
    transition: color 0.12s, border-color 0.12s;
}
.pcf-div-item:hover, .pcf-sec-item:hover {
    color: #5A3A10;
    border-bottom-color: #9B8050;
}
.pcf-div-item.pcf-nav-active, .pcf-sec-item.pcf-nav-active {
    color: #1A0E00;
}
.pcf-div-item.pcf-nav-active::before, .pcf-sec-item.pcf-nav-active::before {
    content: '▶ ';
    font-size: 0.42rem;
    vertical-align: middle;
}

/* IDENTIFICATION → Impressum */
.pcf-fh-id {
    text-decoration: none;
    cursor: pointer;
    transition: background-color 0.12s;
}
.pcf-fh-id:hover { background-color: rgba(195,168,64,0.12); }
.pcf-id-track {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 1px;
    margin-top: 2px;
}
.pcf-id-box {
    width: 9px; height: 11px;
    border: 1px solid #C2A840;
    background: #F0E4B8;
    flex-shrink: 0;
    transition: background-color 0.12s;
}
.pcf-fh-id:hover .pcf-id-box { background: #E8D890; }
.pcf-id-n { font-size: 0.36rem; color: #9B8050; line-height: 1; }

/* ── CODING AREA ────────────────────────────────────────────────────────── */
.pcf-coding-area {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-height: 0;
    overflow: hidden;
}

/* Shared row layout: linenum(32px) | seq(72px) | chars(flex 1) */
.pcf-zone-row, .pcf-ruler-row, .pcf-line-row {
    display: flex;
    flex-direction: row;
    align-items: stretch;
}

/* Zone label row */
.pcf-zone-row {
    height: 15px;
    background: #EDE0A8;
    border-bottom: 1.5px solid #C2A840;
    flex-shrink: 0;
    align-items: center;
}
.pcf-zone-linenum, .pcf-zone-seq, .pcf-zone-stmt {
    font-size: 0.34rem;
    color: #9B8050;
    letter-spacing: 0.08em;
    display: flex;
    align-items: center;
    justify-content: center;
}
.pcf-zone-linenum { width: 32px; flex-shrink: 0; border-right: 1px solid #D4C478; }
.pcf-zone-seq     { width: 72px; flex-shrink: 0; border-right: 1.5px solid #C2A840; }
.pcf-zone-stmt    { flex: 1; }

/* Rulers */
.pcf-ruler-row {
    height: 13px;
    background: #EDE0A8;
    border-bottom: 1px solid #D4C478;
    flex-shrink: 0;
    align-items: center;
}
.pcf-ruler-btm { border-bottom: none; border-top: 1px solid #D4C478; }
.pcf-ruler-linenum { width: 32px; flex-shrink: 0; border-right: 1px solid #D4C478; height: 100%; }

/* Seq ruler: space-evenly matches the per-digit content spans */
.pcf-ruler-seq {
    width: 72px;
    flex-shrink: 0;
    border-right: 1.5px solid #C2A840;
    display: flex;
    justify-content: space-evenly;
    align-items: center;
    font-size: 0.58rem;
}
.pcf-rseq-tick {
    flex: 1;
    text-align: center;
    font-size: 0.58rem;
    color: #9B8050;
    opacity: 0.7;
}

/* Chars ruler: flex, tick widths set by JS to match real content span px width */
.pcf-ruler-chars {
    flex: 1;
    display: flex;
    overflow: hidden;
    align-items: center;
}
.pcf-rchars-tick {
    display: inline-block;
    text-align: right;
    font-size: 0.34rem;
    color: #9B8050;
    flex-shrink: 0;
    overflow: hidden;
    /* width set by JS after first paint */
}

/* Punch area */
.pcf-punch-area {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-height: 0;
    overflow: hidden;
    background-image:
        radial-gradient(ellipse 9% 7% at 74% 68%, rgba(125,75,10,0.10) 0%, rgba(125,75,10,0.03) 55%, transparent 100%);
}
.pcf-line-row {
    flex: 1;
    min-height: 0;
    border-bottom: 1px solid #D4C478;
    flex-shrink: 1;
}
.pcf-line-row:last-child { border-bottom: none; }
.pcf-line-row:nth-child(4n+1) { border-bottom-color: #CEB870; }
.pcf-line-row:nth-child(7n+3) { border-bottom-color: #DDD090; }

/* Line numbers */
.pcf-line-num {
    width: 32px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.72rem;
    color: #7A6020;
    background: #EDE0A8;
    border-right: 1px solid #D4C478;
}

/* Sequence column: space-evenly with per-digit child spans */
.pcf-seq {
    width: 72px;
    flex-shrink: 0;
    display: flex;
    justify-content: space-evenly;
    align-items: center;
    font-size: 0.58rem;
    color: var(--text-muted);
    background: #EDE0A8;
    border-right: 1.5px solid #C2A840;
}
.pcf-seq-digit {
    flex: 1;
    text-align: center;
}

/* Content area */
.pcf-chars {
    display: flex;
    align-items: center;
    overflow: hidden;
    flex: 1;
}
.pcf-chars span {
    display: inline-block;
    width: 1ch;
    text-align: center;
    line-height: 1;
    position: relative;
    flex-shrink: 0;
}

/* Wear: ink pressure */
.pcf-chars span:not(.pcc-empty):nth-child(7n)    { opacity: 0.79; }
.pcf-chars span:not(.pcc-empty):nth-child(11n+2) { opacity: 0.88; }
.pcf-chars span:not(.pcc-empty):nth-child(13n+5) { opacity: 0.82; }
.pcf-chars span:not(.pcc-empty):nth-child(17n)   { opacity: 0.91; }
