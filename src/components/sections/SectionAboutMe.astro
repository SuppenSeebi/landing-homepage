                    </div>
                    <div class="cobol-line l10 reveal-item">
                        <span class="lvl">10</span><span class="name">SINCE</span><span class="pic">PIC 9(4)</span><span class="kw">VALUE</span><span class="numval">2025</span><span class="dot">.</span>
                    </div>

                    <!-- WORK BEFORE -->
                    <div class="cobol-spacer"></div>
                    <div class="cobol-line l05 reveal-item">
                        <span class="lvl">05</span><span class="name">WORK-BFRE.</span>
                    </div>
                    <div class="cobol-line l10 reveal-item">
                        <span class="lvl">10</span><span class="name">COMPANY</span><span class="pic">PIC X(30)</span><span class="kw">VALUE</span><span class="val">&apos;HILSCHER&apos;</span><span class="dot">.</span>
                    </div>
                    <div class="cobol-line l10 reveal-item">
                        <span class="lvl">10</span><span class="name">ROLE</span><span class="pic">PIC X(30)</span><span class="kw">VALUE</span><span class="val">&apos;C DEVELOPER&apos;</span><span class="dot">.</span>
                    </div>
                    <div class="cobol-line l10 reveal-item">
                        <span class="lvl">10</span><span class="name">TECH</span><span class="pic">PIC X(40)</span><span class="kw">VALUE</span><span class="val">&apos;OPC UA - INDUSTRIAL AUTOMATION&apos;</span><span class="dot">.</span>
                    </div>

                    <!-- STUDIES -->
                    <div class="cobol-spacer"></div>
                    <div class="cobol-line l05 reveal-item">
                        <span class="lvl">05</span><span class="name">STUDIES.</span>
                    </div>
                    <div class="cobol-line l10 reveal-item">
                        <span class="lvl">10</span><span class="name">DEGREE</span><span class="pic">PIC X(5)</span><span class="kw">VALUE</span><span class="val">&apos;MSC&apos;</span><span class="dot">.</span>
                    </div>
                    <div class="cobol-line l10 reveal-item">
                        <span class="lvl">10</span><span class="name">FIELD</span><span class="pic">PIC X(30)</span><span class="kw">VALUE</span><span class="val">&apos;ELECTRICAL ENGINEERING&apos;</span><span class="dot">.</span>
                    </div>
                    <div class="cobol-line l10 reveal-item">
                        <span class="lvl">10</span><span class="name">GRADE</span><span class="pic">PIC X(20)</span><span class="kw">VALUE</span><span class="val">&apos;WITH DISTINCTION&apos;</span><span class="dot">.</span>
                    </div>

                    <!-- PRG-LANGUAGES -->
                    <div class="cobol-spacer"></div>
                    <div class="cobol-line l05 reveal-item">
                        <span class="lvl">05</span><span class="name">PRG-LANGUAGES</span><span class="pic">PIC X(10)</span><span class="dot">.</span>
                    </div>
                    <div class="cobol-line l88 primary reveal-item">
                        <span class="lvl">88</span><span class="name">COBOL</span><span class="kw">VALUE</span><span class="val">&apos;PRIMARY&apos;</span><span class="dot">.</span>
                    </div>
                    <div class="cobol-line l88 primary reveal-item">
                        <span class="lvl">88</span><span class="name">C</span><span class="kw">VALUE</span><span class="val">&apos;PRIMARY&apos;</span><span class="dot">.</span>
                    </div>
                    <div class="cobol-line l88 reveal-item">
                        <span class="lvl">88</span><span class="name">CPP</span><span class="kw">VALUE</span><span class="val">&apos;KNOWN&apos;</span><span class="dot">.</span>
                    </div>
                    <div class="cobol-line l88 reveal-item">
                        <span class="lvl">88</span><span class="name">PYTHON</span><span class="kw">VALUE</span><span class="val">&apos;KNOWN&apos;</span><span class="dot">.</span>
                    </div>
                    <div class="cobol-line l88 reveal-item">
                        <span class="lvl">88</span><span class="name">SQL-DB2</span><span class="kw">VALUE</span><span class="val">&apos;KNOWN&apos;</span><span class="dot">.</span>
                    </div>
                    <div class="cobol-line l88 reveal-item">
                        <span class="lvl">88</span><span class="name">JCL</span><span class="kw">VALUE</span><span class="val">&apos;KNOWN&apos;</span><span class="dot">.</span>
                    </div>
                    <div class="cobol-line l88 reveal-item">
                        <span class="lvl">88</span><span class="name">SHELL</span><span class="kw">VALUE</span><span class="val">&apos;KNOWN&apos;</span><span class="dot">.</span>
                    </div>
                    <div class="cobol-line l88 reveal-item">
                        <span class="lvl">88</span><span class="name">JAVASCRIPT</span><span class="kw">VALUE</span><span class="val">&apos;KNOWN&apos;</span><span class="dot">.</span>
                    </div>
                    <div class="cobol-line l88 reveal-item">
                        <span class="lvl">88</span><span class="name">OPC-UA</span><span class="kw">VALUE</span><span class="val">&apos;KNOWN&apos;</span><span class="dot">.</span>
                    </div>

                    <!-- VOC-LANGUAGES -->
                    <div class="cobol-spacer"></div>
                    <div class="cobol-line l05 reveal-item">
                        <span class="lvl">05</span><span class="name">VOC-LANGUAGES</span><span class="pic">PIC X(10)</span><span class="dot">.</span>
                    </div>
                    <div class="cobol-line l88 reveal-item">
                        <span class="lvl">88</span><span class="name">GERMAN</span><span class="kw">VALUE</span><span class="val">&apos;NATIVE&apos;</span><span class="dot">.</span>
                    </div>
                    <div class="cobol-line l88 reveal-item">
                        <span class="lvl">88</span><span class="name">ENGLISH</span><span class="kw">VALUE</span><span class="val">&apos;C2&apos;</span><span class="dot">.</span>
                    </div>
                    <div class="cobol-line l88 reveal-item">
                        <span class="lvl">88</span><span class="name">JAPANESE</span><span class="kw">VALUE</span><span class="val">&apos;BEGINNER&apos;</span><span class="dot">.</span>
                    </div>

                    <!-- link to impressum -->
                    <div class="cobol-spacer"></div>
                    <a href="#impressum" class="cobol-author-link reveal-item">
                        *&gt; <span class="kw">AUTHOR.</span> — Impressum &amp; Datenschutz
                    </a>

                </div>
            </div>
        </div>
    </div>
</section>

<script>
let revealed = false;

export function statemachineAboutMeRun() {
    if (revealed) return;
    revealed = true;

    const items = document.querySelectorAll<HTMLElement>('#aboutme .reveal-item');
    items.forEach((el, i) => setTimeout(() => el.classList.add('revealed'), i * 35));
}

(window as any).__aboutMeRun = statemachineAboutMeRun;
</script>
