---
---
<div class="logo-wrapper" id="logo-wrapper">
    <div class="logo-wrapper-spotlight"></div>
    <div class="rotating-text">
        <svg width="300" height="300" viewBox="0 0 300 300">
            <defs>
                <path id="circlePath" d="M 150,150 m -100,0 a 100,100 0 1,0 200,0 a 100,100 0 1,0 -200,0" />
            </defs>

            <!-- Fixed: name -->
            <text font-family="Share Tech Mono" font-size="15" fill="#2542A3" dominant-baseline="middle">
                <textPath href="#circlePath" startOffset="0%">Sebastian Schwinn</textPath>
            </text>

            <!-- Fixed: COBOL (primary skill) -->
            <text font-family="Share Tech Mono" font-size="15" fill="#1B2D73" font-weight="bold" dominant-baseline="middle">
                <textPath href="#circlePath" startOffset="29%">COBOL</textPath>
            </text>

            <!-- Fixed: C (primary skill) -->
            <text font-family="Share Tech Mono" font-size="15" fill="#1B2D73" font-weight="bold" dominant-baseline="middle">
                <textPath href="#circlePath" startOffset="39%">C</textPath>
            </text>

            <!-- Cycling label -->
            <text id="logo-cycle" font-family="Share Tech Mono" font-size="15" fill="#2542A3" dominant-baseline="middle">
                <textPath href="#circlePath" startOffset="46%">Electrical Engineer</textPath>
            </text>
        </svg>
    </div>
    <div class="static-logo">
        <img src="/logo.svg" alt="Logo" />
    </div>
</div>

<script>
const cycleLabels = [
    "Electrical Engineer",
    "Software Developer",
    "MSc. w/ dist.",
    "3D Printing",
    "Board Member",
    "RetroCode",
];

let labelIndex = 0;

const cycleEl = document.getElementById("logo-cycle");
if (cycleEl) {
    setInterval(() => {
        labelIndex = (labelIndex + 1) % cycleLabels.length;
        cycleEl.querySelector("textPath")!.textContent = cycleLabels[labelIndex];
    }, 8000);
}
</script>
