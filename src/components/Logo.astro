---
---
<div class="logo-wrapper" id="logo-wrapper">
    <div class="logo-wrapper-spotlight"></div>
    <div class="rotating-text">
        <svg width="300" height="300" viewBox="0 0 300 300">
            <defs>
                <!-- CCW arc — noise covers 65% (234°); seams at θ=27°/153°, endpoints 5° past at θ=32°/148° -->
                <!-- Both endpoints symmetric at y≈203: right (235,203), left (65,203) -->
                <path id="topArc" d="M 235,203 A 100,100 0 1,0 65,203" />

                <!--
                    Noise fade: 3-region mask — middle always white, ends use identical
                    gradients (equalized for symmetry). Transparent at arc endpoint y=203,
                    fully opaque at y=190 (~9° of fade on each side).
                -->
                <linearGradient id="noiseGradR" x1="0" y1="203" x2="0" y2="190"
                    gradientUnits="userSpaceOnUse">
                    <stop offset="0%"   stop-color="white" stop-opacity="0"/>
                    <stop offset="100%" stop-color="white" stop-opacity="1"/>
                </linearGradient>
                <linearGradient id="noiseGradL" x1="0" y1="203" x2="0" y2="190"
                    gradientUnits="userSpaceOnUse">
                    <stop offset="0%"   stop-color="white" stop-opacity="0"/>
                    <stop offset="100%" stop-color="white" stop-opacity="1"/>
                </linearGradient>
                <mask id="noiseMask">
                    <rect x="90"  y="0" width="120" height="300" fill="white"/>
                    <rect x="210" y="0" width="90"  height="300" fill="url(#noiseGradR)"/>
                    <rect x="0"   y="0" width="90"  height="300" fill="url(#noiseGradL)"/>
                </mask>

                <!-- Band fade gradients: angled along arc tangent at each endpoint -->
                <!-- Split points (67,206)/(233,206) are exactly the original marquee seams at θ=146°/34° -->
                <linearGradient id="bandGradL" x1="61" y1="195" x2="67" y2="206"
                    gradientUnits="userSpaceOnUse">
                    <stop offset="0%"   stop-color="#EAF3FF" stop-opacity="0"/>
                    <stop offset="100%" stop-color="#EAF3FF" stop-opacity="0.60"/>
                </linearGradient>
                <linearGradient id="bandGradR" x1="239" y1="195" x2="233" y2="206"
                    gradientUnits="userSpaceOnUse">
                    <stop offset="0%"   stop-color="#EAF3FF" stop-opacity="0"/>
                    <stop offset="100%" stop-color="#EAF3FF" stop-opacity="0.60"/>
                </linearGradient>
                <!-- Rail gradients: each matched to its own arc endpoints -->
                <linearGradient id="railGradInner" x1="70" y1="0" x2="230" y2="0"
                    gradientUnits="userSpaceOnUse">
                    <stop offset="0%"   stop-color="#7AAAF0" stop-opacity="0"/>
                    <stop offset="8%"   stop-color="#7AAAF0" stop-opacity="0.9"/>
                    <stop offset="92%"  stop-color="#7AAAF0" stop-opacity="0.9"/>
                    <stop offset="100%" stop-color="#7AAAF0" stop-opacity="0"/>
                </linearGradient>
                <linearGradient id="railGradOuter" x1="51" y1="0" x2="249" y2="0"
                    gradientUnits="userSpaceOnUse">
                    <stop offset="0%"   stop-color="#7AAAF0" stop-opacity="0"/>
                    <stop offset="8%"   stop-color="#7AAAF0" stop-opacity="0.9"/>
                    <stop offset="92%"  stop-color="#7AAAF0" stop-opacity="0.9"/>
                    <stop offset="100%" stop-color="#7AAAF0" stop-opacity="0"/>
                </linearGradient>
            </defs>

            <!-- Z-order: noise → frosted band → marquee -->

            <!-- 1. Noise (bottom) -->
            <text id="logo-noise" mask="url(#noiseMask)"
                font-family="Share Tech Mono" font-size="15" font-weight="bold"
                fill="#2542A3" dominant-baseline="middle">
                <textPath id="logo-noise-path"
                    href="#topArc" startOffset="0%"
                    textLength="420" lengthAdjust="spacing"></textPath>
            </text>

            <!-- 2. Frosted arc band: left fade → solid middle → right fade -->
            <!-- Each fade segment gradient follows the arc tangent (~63° from horizontal) -->
            <path d="M 61,195 A 100,100 0 0,0 67,206"
                fill="none" stroke="url(#bandGradL)" stroke-width="22"/>
            <path d="M 67,206 A 100,100 0 0,0 233,206"
                fill="none" stroke="#EAF3FF" stroke-width="22" stroke-opacity="0.60"/>
            <path d="M 233,206 A 100,100 0 0,0 239,195"
                fill="none" stroke="url(#bandGradR)" stroke-width="22"/>

            <!-- 2b. Glowing rails — 3 layers per rail: halo → bloom → core -->
            <path d="M 70,190 A 89,89 0 0,0 230,190"
                fill="none" stroke="url(#railGradInner)" stroke-width="14" opacity="0.10"/>
            <path d="M 70,190 A 89,89 0 0,0 230,190"
                fill="none" stroke="url(#railGradInner)" stroke-width="6"  opacity="0.30"/>
            <path d="M 70,190 A 89,89 0 0,0 230,190"
                fill="none" stroke="url(#railGradInner)" stroke-width="1.5" opacity="1.0"/>

            <path d="M 51,200 A 111,111 0 0,0 249,200"
                fill="none" stroke="url(#railGradOuter)" stroke-width="14" opacity="0.10"/>
            <path d="M 51,200 A 111,111 0 0,0 249,200"
                fill="none" stroke="url(#railGradOuter)" stroke-width="6"  opacity="0.30"/>
            <path d="M 51,200 A 111,111 0 0,0 249,200"
                fill="none" stroke="url(#railGradOuter)" stroke-width="1.5" opacity="1.0"/>

            <!-- 3. Marquee (top) -->
            <g id="marquee-group"
               font-family="Share Tech Mono" font-size="15" font-weight="bold"
               fill="#2542A3" text-anchor="middle" dominant-baseline="central">
            </g>
        </svg>
    </div>
    <div class="static-logo">
        <img src="/logo.svg" alt="Logo" />
    </div>
</div>

<script>
const NOISE_SRC    = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789·=<>+-#@!?|~^";
const MARQUEE_TEXT = "SEBASTIAN SCHWINN · COBOL DEVELOPER · RETROCODE · MSC EE W/ DISTINCTION · EMBEDDED C · OPC UA · 3D PRINTING · BOARD MEMBER · TENNIS · TABLE TENNIS · ";

const NOISE_CHARS    = 47;
const NOISE_BUF_SIZE = 200; // circular buffer, much larger than the visible window
const MARQUEE_CHARS  = 22;  // characters visible across the 112° bottom arc (~31%)
const MARQUEE_SPEED  = 4 / 1000; // chars per ms — shared belt speed

// ── Bottom arc: 112° CCW from left seam (θ=146°) to right seam (θ=34°) ──────
const DEG       = Math.PI / 180;
const ARC_START = 146 * DEG;
const ARC_SPAN  = -112 * DEG;

function arcPoint(arcFrac: number): { x: number; y: number; rot: number } {
    const t   = ARC_START + arcFrac * ARC_SPAN;
    const x   = 150 + 100 * Math.cos(t);
    const y   = 150 + 100 * Math.sin(t);
    const rot = Math.atan2(-Math.cos(t), Math.sin(t)) * (180 / Math.PI);
    return { x, y, rot };
}

// ── DOM setup ─────────────────────────────────────────────────────────────────
const noisePath    = document.getElementById("logo-noise-path") as SVGTextPathElement;
const marqueeGroup = document.getElementById("marquee-group")   as SVGGElement;

// Pre-create MARQUEE_CHARS+2 <text> nodes (one overflow char per seam)
const charEls: SVGTextElement[] = [];
for (let i = 0; i <= MARQUEE_CHARS + 1; i++) {
    const el = document.createElementNS("http://www.w3.org/2000/svg", "text");
    el.setAttribute("x", "0");
    el.setAttribute("y", "0");
    marqueeGroup.appendChild(el);
    charEls.push(el);
}

// ── Noise circular buffer ─────────────────────────────────────────────────────
function rndChar(): string {
    return NOISE_SRC[Math.floor(Math.random() * NOISE_SRC.length)];
}
const noiseBuffer: string[] = Array.from({ length: NOISE_BUF_SIZE }, rndChar);
let noiseCharWindow = 0; // index of the char currently at the right-seam end

// ── Scroll state ──────────────────────────────────────────────────────────────
let charWindow = 0;
let subChar    = 0;
let lastTime   = 0;

function tick(now: number) {
    const dt = Math.min(50, Math.max(1, lastTime === 0 ? 16 : now - lastTime));
    lastTime = now;

    // ── Advance the shared belt ────────────────────────────────────────────
    subChar += MARQUEE_SPEED * dt;
    while (subChar >= 1) {
        charWindow = (charWindow + 1) % MARQUEE_TEXT.length;
        // A new random char enters the noise arc at the left seam
        noiseBuffer[(noiseCharWindow + NOISE_CHARS) % NOISE_BUF_SIZE] = rndChar();
        noiseCharWindow = (noiseCharWindow + 1) % NOISE_BUF_SIZE;
        subChar -= 1;
    }

    // ── Noise: same CW rotation as marquee ────────────────────────────────
    // The noise textPath runs right-seam → over top → left-seam (opposite CW direction),
    // so CW motion requires startOffset to decrease — chars travel toward the path start
    // (right seam). One char-width % = 100/NOISE_CHARS; startOffset sweeps that range
    // from full (subChar=0) down to 0 (subChar→1), then the content window steps forward.
    const startOffsetPct = (1 - subChar) * (100 / NOISE_CHARS);
    noisePath.setAttribute('startOffset', `${startOffsetPct.toFixed(4)}%`);
    // Every char in transit gets a new random glyph each frame — locked in only when it
    // crosses the right seam and the marquee takes over with the real text.
    let noiseContent = '';
    for (let i = 0; i < NOISE_CHARS; i++) {
        const idx = (noiseCharWindow + i) % NOISE_BUF_SIZE;
        noiseBuffer[idx] = rndChar();
        noiseContent += noiseBuffer[idx];
    }
    noisePath.textContent = noiseContent;

    // ── Marquee: right-to-left, chars enter from right seam ───────────────
    for (let i = 0; i <= MARQUEE_CHARS + 1; i++) {
        const { x, y, rot } = arcPoint((i - subChar) / MARQUEE_CHARS);
        charEls[i].setAttribute("transform",
            `translate(${x.toFixed(2)},${y.toFixed(2)}) rotate(${rot.toFixed(2)})`);
        charEls[i].textContent =
            MARQUEE_TEXT[(charWindow + i) % MARQUEE_TEXT.length];
    }

    requestAnimationFrame(tick);
}

requestAnimationFrame(tick);
</script>
