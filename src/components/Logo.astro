---
---
<div class="logo-wrapper" id="logo-wrapper">
    <div class="logo-wrapper-spotlight"></div>
    <div class="rotating-text">
        <svg width="300" height="300" viewBox="0 0 300 300">
            <defs>
                <!-- CW: left (9) → top (12) → right (3) -->
                <path id="topArc"    d="M 50,150 A 100,100 0 0,1 250,150" />
                <!-- CCW: left (9) → bottom (6) → right (3) -->
                <path id="bottomArc" d="M 50,150 A 100,100 0 0,0 250,150" />
            </defs>
            <!-- Noise: fixed positions, textLength fills arc exactly -->
            <text id="logo-noise" font-family="Share Tech Mono" font-size="15" font-weight="bold" fill="#2542A3" dominant-baseline="middle">
                <textPath id="logo-noise-path" href="#topArc" startOffset="0%" textLength="314" lengthAdjust="spacing"></textPath>
            </text>
            <!-- Marquee: no textLength — startOffset is animated for smooth scroll -->
            <text id="logo-marquee" font-family="Share Tech Mono" font-size="15" font-weight="bold" fill="#2542A3" dominant-baseline="middle">
                <textPath id="logo-marquee-path" href="#bottomArc" startOffset="0%"></textPath>
            </text>
        </svg>
    </div>
    <div class="static-logo">
        <img src="/logo.svg" alt="Logo" />
    </div>
</div>

<script>
const NOISE_SRC    = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789·=<>+-#@!?|~^";
const MARQUEE_TEXT = "SEBASTIAN SCHWINN · COBOL DEVELOPER · RETROCODE · MSC EE W/ DISTINCTION · EMBEDDED C · OPC UA · 3D PRINTING · BOARD MEMBER · TENNIS · TABLE TENNIS · ";

// Semicircle arc length = π×100 ≈ 314 SVG units.
// font-size 15 bold Share Tech Mono ≈ 9 SVG units/char → ~35 chars per arc.
const CHARS = 35;
const CHAR_WIDTH_PCT = 100 / CHARS; // arc-% occupied by one character

// Noise: each character independently flickers at ~5 Hz, FPS-independent.
// P(char changes in dt ms) = dt / CHAR_INTERVAL_MS
const CHAR_INTERVAL_MS = 200;

// Marquee: 4 chars/sec smooth pixel-level scroll, FPS-independent.
const MARQUEE_SPEED = 4 / 1000; // chars per ms

const noisePath   = document.getElementById("logo-noise-path")   as SVGTextPathElement;
const marqueePath = document.getElementById("logo-marquee-path") as SVGTextPathElement;

// Initialise noise characters
const noiseChars = Array.from({ length: CHARS }, () =>
    NOISE_SRC[Math.floor(Math.random() * NOISE_SRC.length)]
);
noisePath.textContent = noiseChars.join("");

let charWindow = 0;   // index of first visible char in MARQUEE_TEXT
let subChar    = 0;   // fractional char advance (0–1)
let lastTime   = 0;

function tick(now: number) {
    const dt = lastTime === 0 ? 16 : now - lastTime;
    lastTime = now;

    // ── Noise: per-character probabilistic flicker ─────────────────────
    // Each char has an independent P(change) = dt / CHAR_INTERVAL_MS per frame.
    // At any FPS this averages to ~5 changes/sec per character.
    const p = Math.min(1, dt / CHAR_INTERVAL_MS);
    let changed = false;
    for (let i = 0; i < CHARS; i++) {
        if (Math.random() < p) {
            noiseChars[i] = NOISE_SRC[Math.floor(Math.random() * NOISE_SRC.length)];
            changed = true;
        }
    }
    if (changed) noisePath.textContent = noiseChars.join("");

    // ── Marquee: smooth sub-character scroll via startOffset ───────────
    // Advance fractional char position; when it crosses 1, shift the window.
    subChar += MARQUEE_SPEED * dt;
    while (subChar >= 1) {
        charWindow = (charWindow + 1) % MARQUEE_TEXT.length;
        subChar -= 1;
    }
    // One extra char so the entering character is visible on the right edge.
    marqueePath.textContent = (MARQUEE_TEXT + MARQUEE_TEXT).slice(charWindow, charWindow + CHARS + 1);
    // Negative startOffset shifts text left by the sub-character fraction,
    // creating pixel-smooth scrolling without discrete jumps.
    marqueePath.setAttribute("startOffset", `${-subChar * CHAR_WIDTH_PCT}%`);

    requestAnimationFrame(tick);
}

requestAnimationFrame(tick);
</script>
